      "id": 1,
      "type": "stat",
      "title": "GPU Utilisation",
      "datasource": {
        "type": "prometheus",
        "uid": "stbc-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "stbc-prometheus"
          },
          "expr": "sum(stoomboot_slots_claimed_total{cluster=\"gpu\"}) / clamp_min(sum(stoomboot_slots_total{cluster=\"gpu\"}),1)",
          "legendFormat": "",
          "instant": true,
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
