{
  "title": "Stoomboot \u2014 Details",
  "uid": "stbc-details",
  "tags": [
    "stoomboot",
    "details"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "15s",
      "30s",
      "1m",
      "5m"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "custom",
        "label": "Cluster",
        "query": "All : .* , GPU : gpu , CPU : cpu",
        "current": {
          "text": "GPU",
          "value": "gpu"
        },
        "options": [
          {
            "text": "All",
            "value": ".*",
            "selected": false
          },
          {
            "text": "GPU",
            "value": "gpu",
            "selected": true
          },
          {
            "text": "CPU",
            "value": "cpu",
            "selected": false
          }
        ],
        "includeAll": false,
        "multi": false,
        "hide": 0
      },
      {
        "name": "user",
        "type": "query",
        "label": "User",
        "datasource": {
          "type": "prometheus",
          "uid": "stbc-prometheus"
        },
        "definition": "label_values(stoomboot_user_jobs_running{cluster=~\"$cluster\"}, user)",
        "query": {
          "query": "label_values(stoomboot_user_jobs_running{cluster=~\"$cluster\"}, user)",
          "refId": "userVar"
        },
        "current": {
          "text": "__DEFAULT_USER__",
          "value": "__DEFAULT_USER__"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "regex": ""
      },
      {
        "name": "job",
        "type": "query",
        "label": "Job",
        "datasource": {
          "type": "prometheus",
          "uid": "stbc-prometheus"
        },
        "definition": "label_values(stoomboot_job_duration_seconds{cluster=~\"$cluster\", user=~\"$user\"}, job_id)",
        "query": {
          "query": "label_values(stoomboot_job_duration_seconds{cluster=~\"$cluster\", user=~\"$user\"}, job_id)",
          "refId": "jobVar"
        },
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "hide": 0,
        "regex": ""
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Jobs running",
      "datasource": {
        "type": "prometheus",
        "uid": "stbc-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "stbc-prometheus"
          },
          "expr": "sum(stoomboot_user_jobs_running{cluster=~\"$cluster\", user=~\"$user\"})",
          "legendFormat": "",
          "instant": true,
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
