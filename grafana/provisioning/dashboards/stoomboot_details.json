          "datasource": {
            "type": "prometheus",
            "uid": "stbc-prometheus"
          },
          "expr": "stoomboot_job_memory_usage_mb{cluster=~\"$cluster\"} / clamp_min(stoomboot_job_memory_requested_mb{cluster=~\"$cluster\"}, 1)",
