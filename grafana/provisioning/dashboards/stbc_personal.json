{
  "title": "My Jobs",
  "uid": "stbc-personal",
  "tags": ["stoomboot", "personal"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "3s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": { "refresh_intervals": ["3s","5s","10s","15s","30s","1m","5m"] },
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "custom",
        "label": "Cluster",
        "query": "GPU : gpu , CPU : cpu",
        "current": { "text": "GPU", "value": "gpu" },
        "options": [
          { "text": "GPU", "value": "gpu", "selected": true },
          { "text": "CPU", "value": "cpu", "selected": false }
        ],
        "includeAll": false,
        "multi": false,
        "hide": 0
      },
      {
        "name": "job",
        "type": "query",
        "label": "Job",
        "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
        "definition": "label_values(stoomboot_job_duration_seconds{user=\"__DEFAULT_USER__\", cluster=\"$cluster\"}, job_id)",
        "query": {
          "query": "label_values(stoomboot_job_duration_seconds{user=\"__DEFAULT_USER__\", cluster=\"$cluster\"}, job_id)",
          "refId": "jobVar"
        },
        "multi": false,
        "refresh": 2,
        "sort": 4,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Jobs running",
      "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
        "expr": "(sum(stoomboot_user_jobs_running{user=\"__DEFAULT_USER__\", cluster=\"$cluster\"}) or vector(0))",
        "instant": true, "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }, "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Jobs queued",
      "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
        "expr": "(sum(stoomboot_user_jobs_queued{user=\"__DEFAULT_USER__\", cluster=\"$cluster\"}) or vector(0))",
        "instant": true, "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }, "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Running for",
      "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
        "expr": "(max(stoomboot_job_duration_seconds{user=\"__DEFAULT_USER__\", cluster=\"$cluster\", job_id=~\"$job\"}) or vector(0))",
        "instant": true, "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }, "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Units in use",
      "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
        "expr": "(sum(stoomboot_user_units_in_use{user=\"__DEFAULT_USER__\", cluster=\"$cluster\"}) or vector(0))",
        "instant": true, "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }, "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "auto", "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "RAM usage",
      "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 9 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
          "expr": "stoomboot_job_memory_usage_mb{user=\"__DEFAULT_USER__\", cluster=\"$cluster\", job_id=~\"$job\"}",
          "legendFormat": "used — {{job_id}}", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
          "expr": "stoomboot_job_memory_requested_mb{user=\"__DEFAULT_USER__\", cluster=\"$cluster\", job_id=~\"$job\"}",
          "legendFormat": "requested — {{job_id}}", "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes", "min": 0,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "spanNulls": true }
        },
        "overrides": [{
          "matcher": { "id": "byFrameRefID", "options": "B" },
          "properties": [
            { "id": "custom.lineStyle", "value": { "dash": [6,3], "fill": "dash" } },
            { "id": "custom.fillOpacity", "value": 0 }
          ]
        }]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU usage",
      "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 9 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "stbc-prometheus" },
        "expr": "stoomboot_job_cpu_efficiency{user=\"__DEFAULT_USER__\", cluster=\"$cluster\", job_id=~\"$job\"}",
        "legendFormat": "{{job_id}}", "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never", "spanNulls": true }
        }, "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 8,
      "type": "text",
      "title": "Job Log Output",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 14 },
      "options": {
        "mode": "html",
        "content": "<div style=\"height:100%;display:flex;flex-direction:column;padding:4px;box-sizing:border-box;gap:6px;\">\n  <p style=\"color:#888;font-size:11px;margin:0;flex-shrink:0;\">Select a specific job from the dropdown above to view its log. Last 200 lines. <a href=\"http://localhost:9119/logs/${job}\" target=\"_blank\" style=\"color:#6ec0e8;\">Open in new tab</a></p>\n  <iframe src=\"http://localhost:9119/logs/${job}\" style=\"flex:1;border:1px solid #333;border-radius:3px;min-height:0;\" title=\"log ${job}\"></iframe>\n</div>",
        "code": { "language": "plaintext", "showLineNumbers": false, "showMiniMap": false }
      }
    }
  ]
}
